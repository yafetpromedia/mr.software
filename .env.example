# Copy to .env.local (never commit real keys)

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mr_software"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"

# Temporarily block registration and non-admin login while you work (admin can still sign in)
# AUTH_LOCK=true

# Mr.Software AI — revoke and rotate keys if ever exposed
AI_BASE_URL=https://api.freemodel.dev/v1
AI_MODEL=claude-t0
AI_API_KEY=fe_o

# Stripe / payments (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — deploy from repository (optional)
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Required for auto-deploy on git push (generate: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=""

# App URL (used for links, deploy URLs, GitHub webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_PUBLIC_ORIGIN="http://localhost:3000"

# Deploy storage — local disk (default) or S3
# LOCAL_DEPLOY_ROOT="./data/deployments"
# DEPLOY_STORAGE=s3
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""
# S3_FORCE_PATH_STYLE=false

# Branded deployment subdomains (optional)
# DEPLOYMENT_PUBLIC_HOST="mr.software"
# DEPLOYMENT_USE_SUBDOMAIN=true

# Browser push (Web Push / VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_SUBJECT="mailto:support@mrsoftware.local"

# Email digests via Resend (optional) — https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Mr.Software <notifications@yourdomain.com>"

# Cron secret for scheduled jobs (e.g. daily notification digest)
CRON_SECRET=""
