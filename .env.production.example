# Copy to .env.production on your VPS — NEVER commit the real file.
# Generate secrets: npm run prod:secrets

# --- Postgres (docker-compose.prod.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=mr_software
APP_PORT=3000

# --- App (required) ---
JWT_SECRET=
NEXT_PUBLIC_APP_URL=https://mrsoftware-et.com
AUTH_PUBLIC_ORIGIN=https://mrsoftware-et.com
# Auth cookies auto-detect HTTP vs HTTPS from the request. Override if needed:
# AUTH_COOKIE_SECURE=false

# Docker Compose: host must be `db` (the postgres service name). Use the same password as POSTGRES_PASSWORD.
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/mr_software?schema=public
# Bare-metal (no Docker): point DATABASE_URL at your managed Postgres host instead.

# --- GitHub deploy + auto-deploy on push ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# --- Google sign-in (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe marketplace (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Deploy storage (pick one) ---
# Local disk (default in Docker — persisted volume):
LOCAL_DEPLOY_ROOT=/var/mr-software/deployments

# S3 / R2 / MinIO (recommended for multi-instance):
# DEPLOY_STORAGE=s3
# S3_BUCKET=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=false

# --- Branded deploy subdomains (optional — needs wildcard DNS + proxy) ---
# DEPLOYMENT_PUBLIC_HOST=mrsoftware-et.com
# DEPLOYMENT_USE_SUBDOMAIN=true

# --- AI (optional) ---
AI_API_KEY=
AI_BASE_URL=https://api.freemodel.dev/v1
AI_MODEL=claude-t0

# --- Notifications (optional) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:support@mrsoftware-et.com
RESEND_API_KEY=
EMAIL_FROM="MrSoftware ET <notifications@mrsoftware-et.com>"
CRON_SECRET=
