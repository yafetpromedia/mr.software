# Reverse proxy for mrsoftware-et.com on a VPS
# Install Caddy: https://caddyserver.com/docs/install
# Run from repo root: caddy run --config deploy/Caddyfile
#
# Requires ports 80/443 open. Caddy obtains TLS automatically.

mrsoftware-et.com, www.mrsoftware-et.com {
	encode gzip zstd
	reverse_proxy localhost:3000
}

# Optional: wildcard for branded deployment subdomains
# *.mrsoftware-et.com {
# 	encode gzip zstd
# 	reverse_proxy localhost:3000
# }
