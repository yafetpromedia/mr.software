generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  DEVELOPER
  ADMIN
}

enum UserStatus {
  ACTIVE
  RESTRICTED
  SUSPENDED
  BANNED
}

/** How the product is sold */
enum PricingModel {
  FREE
  ONE_TIME
  SUBSCRIPTION
}

enum LicenseKind {
  ONE_TIME
  SUBSCRIPTION
}

/** How the product may be used (marketplace license tier). */
enum ProductLicenseTier {
  PERSONAL
  COMMERCIAL
  ENTERPRISE
  OPEN_SOURCE
}

enum OpenSourceLicense {
  MIT
  APACHE_2
  GPL
  BSD
}

/** How buyers receive the product (developer choice at publish). */
enum DistributionType {
  SOURCE_CODE
  COMPILED
  HOSTED
}

enum SoftwareLicenseKeyStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PurchaseStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELED
  REFUNDED
}

/** Workspace plan for deployment limits (not marketplace purchase) */
enum Plan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
}

enum DeploymentStatus {
  PENDING
  ACTIVE
  FAILED
}

/** How a deployment is served after build */
enum DeployRuntime {
  STATIC
  NODE
  PHP
  PYTHON
}

/** Marketplace product verticals (Mr.Software 2.0 catalog). */
enum SoftwareCategory {
  EDUCATION
  HEALTHCARE
  BUSINESS
  FINANCE
  ECOMMERCE
  GOVERNMENT
  AI_TOOLS
  DEVELOPER_TOOLS
  TEMPLATES
  APIS
}

enum PaymentProvider {
  STRIPE
  CHAPA
  TELEBIRR
  DEV_GRANT
}

enum AcademyCourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

/** Visual theme for public developer storefronts. */
enum StorefrontTheme {
  CLASSIC
  MINIMAL
  BOLD
  MIDNIGHT
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  /** Null for Google-only accounts */
  password  String?
  /** Google OAuth subject (`sub`); set when the user has signed in with Google */
  googleId  String?    @unique
  /** Stripe Customer id for Checkout / subscriptions */
  stripeCustomerId String? @unique
  /** Increment to invalidate all JWTs for this user */
  sessionVersion Int    @default(1)
  role      Role       @default(USER)
  status    UserStatus @default(ACTIVE)
  canUpload   Boolean @default(true)
  canPublish  Boolean @default(true)
  canWithdraw Boolean @default(true)
  createdAt DateTime   @default(now())

  softwareDeveloped Software[] @relation("DeveloperSoftware")
  purchases         Purchase[]
  deployments       Deployment[]
  subscription      Subscription?
  workspacePlanCheckouts WorkspacePlanCheckout[]
  adminAuditLogs    AdminAuditLog[] @relation("AdminAuditAuthor")
  generatedStartups GeneratedStartup[]
  aiConversations   AiConversation[]
  storefront          DeveloperStorefront?
  storefrontFollows   StorefrontFollower[] @relation("StorefrontFollower")
  academyProgress     AcademyProgress[]
  githubConnection    GitHubConnection?
  notifications       Notification[]
  notificationPreferences NotificationPreferences?
  pushSubscriptions   PushSubscription[]
  reportsFiled        UserReport[] @relation("ReportsFiled")
  reportsResolved     UserReport[] @relation("ReportsResolved")
  developerAccessRequests DeveloperAccessRequest[]
  developerAccessReviews  DeveloperAccessRequest[] @relation("DeveloperAccessReviewed")
  factorySessions         FactorySession[]
  ownershipRecords        OwnershipRecord[]
  softwareLicenseKeys     SoftwareLicenseKey[]
  developerMemoryProfile  DeveloperMemoryProfile?
}

/** Personalized AI context for a creator — separate from legal ownership & license records. */
model DeveloperMemoryProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** Creator identity: developer, vision, projects, skills */
  profileJson    Json @default("{}")
  /** Design language: style, colors, focus areas, values */
  creatorDnaJson Json @default("{}")
  /** AI team metadata (founder, aiArchitect, aiDeveloper) */
  teamJson       Json @default("{}")

  /** Active project focus injected into AI requests */
  currentProjectName     String?
  currentProjectCategory String?

  /** Optional free-form notes for AI (not legal ownership data) */
  aiContextNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Public developer identity at `/@handle` — core of the 2.0 ecosystem model. */
model DeveloperStorefront {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** URL slug: mr.software/@handle */
  handle    String   @unique
  tagline   String?
  bio       String?  @db.Text
  website   String?
  /** JSON map of platform id → profile URL (twitter, github, linkedin, etc.) */
  socialLinksJson String @default("{}") @db.Text
  theme     StorefrontTheme @default(CLASSIC)
  /** Platform-verified creator badge (admin-granted) */
  verified  Boolean         @default(false)
  verifiedAt DateTime?
  /** When true, lifetime sales total is shown on the public store */
  showRevenuePublic Boolean @default(false)
  /** Featured on marketplace / landing (e.g. YafetPromedia flagship) */
  featured  Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  followers StorefrontFollower[] @relation("StorefrontFollows")

  @@index([featured])
}

/** Users following a developer storefront. */
model StorefrontFollower {
  id               String   @id @default(cuid())
  storefrontUserId String
  followerUserId   String
  createdAt        DateTime @default(now())

  storefront DeveloperStorefront @relation("StorefrontFollows", fields: [storefrontUserId], references: [userId], onDelete: Cascade)
  follower   User                @relation("StorefrontFollower", fields: [followerUserId], references: [id], onDelete: Cascade)

  @@unique([storefrontUserId, followerUserId])
  @@index([followerUserId])
}

/** AI-generated startup package (MVP: builder → landing → dashboard preview). */
model GeneratedStartup {
  id            String   @id @default(cuid())
  userId        String
  idea          String   @db.Text
  generatedJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum FactoryStep {
  IDEA
  VALIDATION
  PACKAGE
  DEPLOY
  STOREFRONT
  LISTING
  COMPLETE
}

/** Guided startup creation flow — idea through marketplace listing. */
model FactorySession {
  id             String      @id @default(cuid())
  userId         String
  idea           String      @db.Text
  currentStep    FactoryStep @default(IDEA)
  analysisJson   Json?
  conversationId String?
  startupId      String?
  deploymentId   String?
  softwareId     String?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

/** GitHub OAuth link for deploy-from-repo (separate from Google login). */
model GitHubConnection {
  userId      String   @id
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubId    Int
  login       String
  accessToken String   @db.Text
  scope       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum NotificationKind {
  DEPLOYMENT
  AI
  MARKETPLACE
  BILLING
  STOREFRONT
  SYSTEM
}

enum EmailDigestFrequency {
  OFF
  DAILY
  WEEKLY
}

/** Per-user notification delivery preferences. */
model NotificationPreferences {
  userId       String               @id
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mutedKinds   NotificationKind[]
  pushEnabled  Boolean              @default(false)
  emailDigest  EmailDigestFrequency @default(OFF)
  lastDigestAt DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

/** Browser Web Push subscription (VAPID). */
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

/** In-app notification delivered in real time via SSE. */
model Notification {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         NotificationKind
  title        String
  body         String           @db.Text
  href         String?
  readAt       DateTime?
  digestSentAt DateTime?
  createdAt    DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([userId, digestSentAt])
}

/** Mr.Software AI product surface (Advisor, Architect, Launchpad, etc.). */
enum AiProduct {
  STARTUP_ADVISOR
  ARCHITECT
  LAUNCHPAD
  COPILOT
  MARKETPLACE_ASSISTANT
}

/** Saved AI workspace conversation. */
model AiConversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   AiProduct @default(STARTUP_ADVISOR)
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages AiMessage[]

  @@index([userId, product])
  @@index([createdAt])
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /** user | assistant | system */
  role           String
  content        String   @db.Text
  /** Structured AI output (analysis JSON, blueprint, etc.) */
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

/** Immutable log of privileged admin actions (trust & safety / compliance). */
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminAuditAuthor", fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  targetType String
  targetId   String?
  detail     Json?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Software {
  id            String   @id @default(uuid())
  name          String
  description   String   @db.Text
  /** Human-readable price label for UI, e.g. "Free", "$9.99", "$29/mo" */
  price         String
  pricingModel  PricingModel @default(ONE_TIME)
  /** Minor units (e.g. cents). Used for Stripe and sorting; 0 for free */
  priceCents    Int      @default(0)
  currency      String   @default("usd")
  /**
   * Private asset location — never exposed in public API responses.
   * @map preserves existing `downloadUrl` column name in the database.
   */
  assetUrl      String   @map("downloadUrl")
  /** Stripe Price id (`price_...`) for Checkout line items */
  stripePriceId String?
  /** Cover image for marketplace cards and detail hero */
  thumbnailUrl  String?
  /** Optional Google Play listing for mobile apps */
  playStoreUrl  String?
  /** Optional Apple App Store listing for mobile apps */
  appStoreUrl   String?
  category      SoftwareCategory @default(DEVELOPER_TOOLS)
  licenseTier   ProductLicenseTier @default(PERSONAL)
  openSourceLicense OpenSourceLicense?
  /** How the product is delivered to buyers */
  distributionType DistributionType @default(COMPILED)
  /** SHA-256 fingerprint of published product metadata / asset reference */
  contentFingerprint String?
  contentSignedAt    DateTime?
  developerId   String
  developer     User     @relation("DeveloperSoftware", fields: [developerId], references: [id], onDelete: Cascade)
  /** Product detail page views */
  viewCount     Int      @default(0)
  /** When false, hidden from marketplace and storefront (owner can still manage) */
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())

  purchases       Purchase[]
  deployments     Deployment[]
  ownershipRecord OwnershipRecord?
  licenseKeys     SoftwareLicenseKey[]
}

/**
 * One entitlement row per user per software (subscription updates same row).
 */
model Purchase {
  id         String   @id @default(uuid())
  userId     String
  softwareId String
  licenseKind LicenseKind
  status     PurchaseStatus @default(PENDING)
  amountCents Int?
  currency   String?
  validFrom  DateTime @default(now())
  /** For subscriptions: current period end. Null = perpetual one-time license */
  validUntil DateTime?
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  stripeSubscriptionId    String? @unique
  paymentProvider         PaymentProvider?
  chapaTxRef              String?         @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  software Software @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  licenseKey SoftwareLicenseKey?

  @@unique([userId, softwareId])
  @@index([userId])
  @@index([softwareId])
}

/** Timestamped ownership record when a product is published (Level 1 trust). */
model OwnershipRecord {
  id            String   @id @default(cuid())
  recordNumber  String   @unique
  softwareId    String   @unique
  developerId   String
  developerName String
  productName   String
  publishedAt   DateTime @default(now())

  software  Software @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  developer User     @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([developerId])
  @@index([publishedAt])
}

/** Per-purchase license key for verification API (Level 2 trust). */
model SoftwareLicenseKey {
  id          String                   @id @default(cuid())
  softwareId  String
  purchaseId  String                   @unique
  userId      String
  licenseKey  String                   @unique
  /** Optional domain lock for web/self-hosted installs (e.g. school.edu.et) */
  licensedDomain String?
  status      SoftwareLicenseKeyStatus @default(ACTIVE)
  expiresAt   DateTime?
  issuedAt    DateTime                 @default(now())
  revokedAt   DateTime?

  software Software @relation(fields: [softwareId], references: [id], onDelete: Cascade)
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([softwareId])
  @@index([userId])
  @@index([licenseKey])
}

/**
 * User workspace billing plan (deployments quota). Separate from marketplace `Purchase`.
 */
model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  plan      Plan               @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  expiresAt DateTime?
  stripeSubscriptionId String? @unique
  paymentProvider      PaymentProvider?
  billingCurrency      String?
  amountCents          Int?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** Workspace Pro checkout attempts (separate from marketplace purchases). */
model WorkspacePlanCheckout {
  id                      String           @id @default(cuid())
  userId                  String
  provider                PaymentProvider
  status                  PurchaseStatus   @default(PENDING)
  chapaTxRef              String?          @unique
  stripeCheckoutSessionId String?          @unique
  stripeSubscriptionId    String?
  currency                String
  amountCents             Int
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Deployment {
  id           String            @id @default(cuid())
  userId       String
  softwareId   String?
  name         String
  /** URL-safe segment; unique per user */
  slug         String
  status       DeploymentStatus  @default(PENDING)
  /** STATIC = files · NODE = Next/Express · PHP · PYTHON */
  runtime      DeployRuntime     @default(STATIC)
  /** Detected stack, e.g. vite, nextjs, php, flask */
  framework    String?
  /** Local port when runtime is NODE, PHP, or PYTHON */
  runtimePort  Int?
  url          String?
  errorMessage String?           @db.Text
  /** GitHub source when deployed from a repo */
  githubOwner     String?
  githubRepo      String?
  githubBranch    String?
  githubWebhookId Int?
  autoDeploy      Boolean          @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  software Software? @relation(fields: [softwareId], references: [id], onDelete: SetNull)

  @@unique([userId, slug])
  @@index([userId])
  @@index([status])
}

model SiteSettings {
  id             Int            @id
  logoUrl        String         @default("/brand/logo-mark.png")
  partnersJson   String         @default("[]") @db.Text
  launchMapMode  LaunchMapMode  @default(HYBRID)
  updatedAt      DateTime       @updatedAt
}

enum LaunchMapMode {
  DEMO
  LIVE
  HYBRID
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

/** Visitor-submitted quotes; admin approves before landing display. */
model Testimonial {
  id           String             @id @default(cuid())
  name         String
  role         String?
  company      String?
  quote        String             @db.Text
  /** 1–5 stars; optional */
  rating       Int?
  /** Contact only — never shown publicly */
  email        String?
  status       TestimonialStatus  @default(PENDING)
  sortOrder    Int                @default(0)
  submittedAt  DateTime           @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  @@index([status, sortOrder])
  @@index([submittedAt])
}

enum TeamMemberKind {
  HUMAN
  AI_CAPABILITY
  ECOSYSTEM
}

/** Landing page team section copy (singleton). */
model TeamSectionSettings {
  id        Int      @id
  eyebrow   String   @default("Team")
  title     String   @default("The Modern Startup Team")
  tagline   String   @default("Built by a Human. Powered by AI.")
  intro     String   @default("Building the future of software with human creativity and AI execution.") @db.Text
  updatedAt DateTime @updatedAt
}

/** Landing page team profiles — managed from admin. */
model TeamMember {
  id        String         @id @default(cuid())
  kind      TeamMemberKind
  name      String
  role      String
  bio       String         @db.Text
  avatarUrl String?
  monogram  String?
  published Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([published, sortOrder])
}

/** Academy catalog page copy (singleton). */
model AcademySectionSettings {
  id        Int      @id
  eyebrow   String   @default("Mr.Software Academy")
  title     String   @default("Learn → build → publish")
  tagline   String   @default("From idea to live product on the marketplace.")
  intro     String   @default("Courses for developers and founders. Finish a track, then publish on the marketplace or open your storefront.") @db.Text
  updatedAt DateTime @updatedAt
}

/** Mr.Software Academy — learn and publish on the platform. */
model AcademyCourse {
  id              String             @id @default(cuid())
  slug            String             @unique
  title           String
  description     String             @db.Text
  level           AcademyCourseLevel @default(BEGINNER)
  durationMinutes Int                @default(60)
  published       Boolean            @default(true)
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  lessons  AcademyLesson[]
  progress AcademyProgress[]

  @@index([published, sortOrder])
}

model AcademyLesson {
  id              String   @id @default(cuid())
  courseId        String
  title           String
  summary         String   @default("") @db.Text
  content         String   @db.Text
  durationMinutes Int      @default(10)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  course AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
}

/** Per-user course completion tracking. */
model AcademyProgress {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  completed   Boolean  @default(false)
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course AcademyCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

enum UserReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum UserReportTargetType {
  SOFTWARE
  STOREFRONT
  USER
}

enum UserReportReason {
  SPAM
  SCAM
  COPYRIGHT
  INAPPROPRIATE
  MISLEADING
  OTHER
}

/** User-submitted abuse / listing reports — triaged from admin. */
model UserReport {
  id           String               @id @default(cuid())
  reporterId   String
  targetType   UserReportTargetType
  targetId     String
  reason       UserReportReason
  details      String?              @db.Text
  status       UserReportStatus     @default(OPEN)
  resolution   String?              @db.Text
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  reporter   User  @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("ReportsResolved", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

enum DeveloperAccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/** Members request promotion to the Developer role — reviewed in admin. */
model DeveloperAccessRequest {
  id           String                       @id @default(cuid())
  userId       String
  pitch        String                       @db.Text
  website      String?
  status       DeveloperAccessRequestStatus @default(PENDING)
  adminNote    String?                      @db.Text
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("DeveloperAccessReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId])
}
